# Audit Army Environment Variables

# Application
NODE_ENV=development
PORT=3001

# PostgreSQL Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=auditarmy
DATABASE_PASSWORD=auditarmy123
DATABASE_NAME=auditarmy

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT / SIWE
JWT_SECRET=your-jwt-secret-key-here
JWT_EXPIRATION=7d

# IPFS
PINATA_API_KEY=your-pinata-api-key
PINATA_API_SECRET=your-pinata-api-secret
PINATA_JWT=your-pinata-jwt-token

# AWS S3 (for sensitive documents)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=audit-army-sensitive-docs

# Blockchain RPC
ETHEREUM_RPC_URL=https://eth-goerli.g.alchemy.com/v2/your-api-key
ETHEREUM_CHAIN_ID=5

# Contract Addresses (will be updated after deployment)
DAO_FACTORY_ADDRESS=
AUDIT_ESCROW_ADDRESS=
REVIEW_SUBMISSION_ADDRESS=
VOTING_ADDRESS=

# Envio Indexer
ENVIO_GRAPHQL_URL=http://localhost:4350
ENVIO_WS_URL=ws://localhost:4350

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id

# Monitoring & Error Tracking
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# Email (for notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@audit.army
